APP_NAME=Autoclipper MVP Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/autoclipper
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=autoclipper-renders
SUPABASE_SIGNED_URL_EXPIRES_IN=3600
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MAX_CANDIDATES_BEFORE_RERANK=12
TEMP_DIR=/tmp/autoclipper
FFMPEG_BINARY=ffmpeg
YTDLP_BINARY=yt-dlp
YTDLP_FORMAT=bv*[vcodec^=avc1][ext=mp4]+ba[ext=m4a]/b[ext=mp4]/best[ext=mp4]/best
DISCOVERY_COMMAND_TIMEOUT_SECONDS=60
RENDER_COMMAND_TIMEOUT_SECONDS=900
RENDER_VIDEO_CRF=18
RENDER_VIDEO_PRESET=veryfast
RENDER_FFMPEG_THREADS=2
RENDER_AUDIO_BITRATE=192k
RENDER_TARGET_WIDTH=720
RENDER_TARGET_HEIGHT=1280
RENDER_BURN_SUBTITLE=true
RENDER_INTRO_VOICE_LANG=id
RENDER_INTRO_VOICE_SPEED=1.08
RENDER_WHISPER_MODEL=small
RENDER_WHISPER_DEVICE=auto
RENDER_WHISPER_COMPUTE_TYPE=int8
RENDER_SUBTITLE_FONT_SIZE=44
RENDER_SUBTITLE_MARGIN_BOTTOM=180
RENDER_SUBTITLE_MAX_WORDS_PER_LINE=4
RENDER_SUBTITLE_MAX_CHARS_PER_LINE=18
RENDER_SUBTITLE_ACTIVE_COLOR_ASS=&H0000FFFF
RENDER_SUBTITLE_CONTEXT_BEFORE=1
RENDER_SUBTITLE_CONTEXT_AFTER=2
RENDER_SUBTITLE_ACTIVE_SCALE_PERCENT=112
RENDER_THUMBNAIL_FONT_PATH=Montserrat-Bold.ttf
RENDER_HOOK_TEXT_OVERLAY_ENABLED=true
