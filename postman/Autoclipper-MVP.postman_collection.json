    {
      "name": "Jobs",
      "item": [
        {
          "name": "POST /api/v1/jobs/analyze",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.job_id) {",
                  "  pm.collectionVariables.set('job_id', jsonData.job_id);",
                  "}",
                  "",
                  "if (jsonData.candidates && jsonData.candidates.length > 0) {",
                  "  pm.collectionVariables.set('candidate_id', jsonData.candidates[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"youtube_url\": \"{{youtube_url}}\",\n  \"keyword\": \"{{keyword}}\",\n  \"duration_target\": {{duration_target}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/analyze",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "analyze"]
            },
            "description": "Analyze YouTube transcript dan generate candidate clips"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?status=&limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                {
                  "key": "status",
                  "value": ""
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "List jobs dengan filter pagination"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/jobs/{job_id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}"]
            },
            "description": "Get detail job by id"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/jobs/{job_id}/render",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_id\": \"{{candidate_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}/render",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}", "render"]
            },
            "description": "Render candidate terpilih lalu upload ke Supabase Storage"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/jobs/{job_id}/schedule",
          "request": {
